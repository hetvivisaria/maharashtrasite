pipeline {
  agent any
  stages {
    stage('Plan') {
      steps {
        bat ' echo \'Planning project...\''
      }
    }

    stage('Build') {
      steps {
        bat 'echo \'Building project...\''
      }
    }

    stage('Test') {
      steps {
        bat ' echo \'Running tests...\''
      }
    }

  }
}